{
  "manifest_version": 2,
  "name": "Hoverleser",
  "version": "1.0.3",
  "description": "Hover over a German word to instantly see its translation, gender, pronunciation and grammar. Offline \u2014 no data sent anywhere.",
  "permissions": [
    "storage",
    "tabs",
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "browser_action": {
    "default_title": "Hoverleser",
    "default_icon": {
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html",
    "default_area": "navbar"
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    "icons/icon128.png"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "addon@hoverleser.app",
      "strict_min_version": "70.0"
    }
  },
  "content_security_policy": "script-src 'self'; object-src 'self'"
}